# Copy to .env and fill in real secrets before deploying. Never commit .env.
# docker compose automatically reads .env in this directory.

# --- Database ---
MYSQL_ROOT_PASSWORD=change-me-strong
DB_USERNAME=root
DB_PASSWORD=change-me-strong

# --- Auth bootstrap admin (created on first start) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=change-me-strong
